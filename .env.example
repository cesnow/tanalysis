# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT="development"

# ── Jira ──────────────────────────────────────────────────────────────────
JIRA_BASE_URL="https://your-domain.atlassian.net"
JIRA_EMAIL="your-email@example.com"
JIRA_API_TOKEN="your-api-token"
JIRA_PROJECT_KEY="YOURPROJ"

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_ENABLED=True
MONGODB_URL="mongodb://root:root@127.0.0.1:27017/?authSource=admin"
MONGODB_DATABASE="tanalysis"
MONGODB_ADDITIONAL_OPTIONS='{}'

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_ENABLED=True
REDIS_URL="redis://localhost:6379/0"

# ── MariaDB ───────────────────────────────────────────────────────────────
MARIADB_URL="mysql+pymysql://root:root@127.0.0.1:3306/tanalysis"

# ── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ENDPOINT="127.0.0.1:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="tanalysis"
MINIO_SECURE=False

# ── Prefect ───────────────────────────────────────────────────────────────
PREFECT_API_URL="http://127.0.0.1:4200/api"

# ── Logging & Observability ───────────────────────────────────────────────
LOG_LEVEL="INFO"
METRICS_ENABLED=True
